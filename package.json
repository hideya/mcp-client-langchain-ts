{
  "name": "@h1deya/mcp-client-cli",
  "version": "0.4.1",
  "description": "Simple MCP Client to quickly test and explore MCP servers from the command line",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "client",
    "cli",
    "langchain",
    "tools",
    "typescript",
    "simple",
    "quick",
    "explore",
    "try",
    "test"
  ],
  "author": "hideya kawahara",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hideya/mcp-client-langchain-ts.git"
  },
  "bugs": {
    "url": "https://github.com/hideya/mcp-client-langchain-ts/issues"
  },
  "bin": {
    "mcp-client-cli": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:h": "tsx src/index.ts -h",
    "start:v": "tsx src/index.ts -v",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "clean": "git clean -fdxn -e .env && read -p '\nOK? ' && git clean -fdx -e .env",
    "test": "echo \"No tests specified\" && exit 0",
    "build": "tsc && chmod +x dist/index.js",
    "publish:prepare": "npm run clean && npm install && npm run build",
    "publish:test": "npm run publish:prepare && npm publish --access=public --dry-run",
    "publish:do": "npm run publish:prepare && npm publish --access=public"
  },
  "dependencies": {
    "@h1deya/langchain-mcp-tools": "^0.4.0",
    "@langchain/anthropic": "^1.3.17",
    "@langchain/cerebras": "^1.0.1",
    "@langchain/google-genai": "^2.1.18",
    "@langchain/groq": "^1.1.0",
    "@langchain/openai": "^1.2.7",
    "@langchain/xai": "^1.3.3",
    "@types/yargs": "^17.0.33",
    "dotenv": "^16.4.7",
    "json5": "^2.2.3",
    "langchain": "^1.2.23",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
